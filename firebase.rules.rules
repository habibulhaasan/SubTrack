rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // exists() guard prevents crash if user doc is missing
    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'superadmin';
    }

    // exists() guard prevents crash if membership doc is missing (e.g. for superadmin)
    function isOrgAdmin(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isApprovedMember(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.get('approved', false) == true;
    }

    function isOwnDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }


    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwnDoc(userId);
      allow update: if isOwnDoc(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }


    // ── Organizations ─────────────────────────────────────────────────────────

    match /organizations/{orgId} {
      allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || isOrgAdmin(orgId);
      allow delete: if isSuperAdmin();


      // ── Members ─────────────────────────────────────────────────────────────

      match /members/{memberId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isOwnDoc(memberId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId) || isOwnDoc(memberId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId)
          || (isOwnDoc(memberId)
              && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'approved']));
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Investments (installment payments) ───────────────────────────────────

      match /investments/{investmentId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── File Library ─────────────────────────────────────────────────────────

      match /files/{fileId} {
        allow read:  if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow write: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Notifications ─────────────────────────────────────────────────────────

      match /notifications/{notifId} {
        allow read:   if isSuperAdmin() || isOrgAdmin(orgId)
          || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
        allow update: if isSuperAdmin() || isOrgAdmin(orgId)
          || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
        allow delete: if isSuperAdmin() || isOrgAdmin(orgId)
          || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
        allow create: if isSuperAdmin() || isOrgAdmin(orgId);
      }


      // ── Catch-all (expenses, deployments, income, penalties, etc.) ────────────

      match /{collection}/{docId} {
        allow read:  if isSuperAdmin() || isOrgAdmin(orgId) || isApprovedMember(orgId);
        allow write: if isSuperAdmin() || isOrgAdmin(orgId);
      }

    } // end organizations/{orgId}


    // ── Invite Links ──────────────────────────────────────────────────────────

    match /invites/{inviteId} {
      allow read:   if true;
      allow create: if isSuperAdmin()
        || (isSignedIn() && isOrgAdmin(request.resource.data.get('orgId', '')));
      allow delete: if isSuperAdmin()
        || (isSignedIn() && isOrgAdmin(resource.data.get('orgId', '')));
      allow update: if false;
    }


    // ── Platform settings ─────────────────────────────────────────────────────

    match /platform/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

  }
}
